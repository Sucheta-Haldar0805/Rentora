        </a>

    <% } else { %>

        <a href="/signup" class="nav-link fw-semibold me-3">
            Sign Up
        </a>

        <a href="/login" class="nav-link fw-semibold me-3">
            Log In
        </a>

    <% } %>

    <button id="theme-toggle" class="theme-btn">
        <i class="fa-solid fa-moon"></i>
    </button>

</div>
