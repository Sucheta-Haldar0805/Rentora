      <img src="/images/logo2.png" alt="Rentora" class="logo">
      <span class="brand-name">
        Rent
        <span class="key-o">
            <span class="keyhole"></span>
        </span>
        ra
  </a>
    <button class="navbar-toggler" type="button" 
        data-bs-toggle="collapse" 
        data-bs-target="#navbarNavAltMarkup"
    >
    <span class="navbar-toggler-icon"></span>
    <h1>Rentora</h1>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
    <div class="navbar-nav ms-4">
      <a class="nav-link explore fw-semibold" href="/listings">
          Explore
      </a>
    </div>


<div class="search-wrapper">

<form action="/listings" method="GET" class="search-bar" id="navSearchForm">

    <!-- Main search -->
    <input
        type="text"
        name="q"
        placeholder="Search destinations..."
        class="search-input"
        value="<%= locals.q || '' %>"
        onfocus="document.getElementById('filterDropdown').classList.add('show')"
    >

    <!-- Filter button -->
    <button type="button" class="filter-toggle-btn" id="filterBtn">
      <i class="fa-solid fa-sliders"></i>
    </button>


    <!-- Search submit -->
    <button type="button" class="search-btn" id="searchFocusBtn">
        <i class="fa-solid fa-magnifying-glass"></i>
    </button>


    <!-- Dropdown filters -->
    <div class="filter-dropdown" id="filterDropdown">

        <input 
            type="number"
            name="minPrice"
            placeholder="Min Price"
            value="<%= locals.minPrice || '' %>"
        >

        <input 
            type="number"
            name="maxPrice"
            placeholder="Max Price"
            value="<%= locals.maxPrice || '' %>"
        >

        <input 
            type="number"
            step="0.1"
            name="minRating"
            placeholder="Minimum Rating"
            value="<%= locals.minRating || '' %>"
        >

    </div>

</form>

</div>



<div class="navbar-nav ms-auto align-items-center">
        <% if(currUser) { %>
            <li class="nav-item">
                <a class="nav-link " href="/wishlist">
                    <i class="fa-solid fa-heart icon"></i> Wishlist
                </a>
            </li>
        <% } %>

    <% if(currUser) { %>

        <a href="/listings/new" class="nav-link fw-semibold me-3">
